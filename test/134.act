deftype STR2(
  int<1> flag;
  int<0> ch
){}

defproc buffer (
    chan?(STR2) IN;
    chan!(STR2) OUT
) {
  STR2 in;
  int<0> x;
  int<1> y;
  int<1> z;
  chp{
 *[ 
     IN?in;
     z:=int(in);
     OUT!STR2(z)
  ]
  }
}

defproc ss (
    chan!(STR2) IN;
    chan?(STR2) OUT
    ) {
      int x;
      chp {
         x := 0;
        *[ x < 100 -> IN!STR2(0),OUT?; x := x + 1 ]
      }
    }

defproc test () {
  buffer db;
  ss s(db.IN, db.OUT);
}
